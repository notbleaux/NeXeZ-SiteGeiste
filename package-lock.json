    "node_modules/@nuevue/relay-registry": {
      "resolved": "apps/relay-registry",
      "link": true
    },
    "node_modules/@nuevue/relay-worker": {
      "resolved": "apps/relay-worker",
      "link": true
    },
    "node_modules/@nuevue/shared-types": {
      "resolved": "packages/shared-types",
