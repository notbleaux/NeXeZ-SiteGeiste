{
  "name": "@nexez/design-tokens",
  "version": "0.1.0",
  "description": "PixelOffice design tokens and theme configuration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "design-tokens",
    "theme",
    "pixeloffice"
  ],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.2.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
